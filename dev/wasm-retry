#!/usr/bin/env bash
# Shared retry logic for WASM cargo test targets.
# Source this file and call: wasm_test_with_retry "<extra_cargo_flags>" "<package_flags>"
#
# Runs cargo test for WASM, then retries any individual failures up to
# MAX_RETRIES times to match nextest's retry behaviour for native tests.

MAX_RETRIES=3
WASM_PACKAGES="-p xmtp_mls -p xmtp_cryptography -p xmtp_common -p xmtp_api -p xmtp_id -p xmtp_db -p xmtp_api_d14n"

wasm_test_with_retry() {
    local extra_flags="${1:-}"
    local packages="${2:-$WASM_PACKAGES}"

    local base_cmd="XMTP_TEST_LOGGING=false RUST_LOG=off cargo test --locked --release --target wasm32-unknown-unknown ${packages} ${extra_flags}"

    echo "==> Running WASM tests"
    local output
    local exit_code

    output=$(eval "$base_cmd" 2>&1)
    exit_code=$?

    echo "$output"

    if [ "$exit_code" -eq 0 ]; then
        return 0
    fi

    # Extract failed test names (lines like "test path::to::test_name ... FAILED")
    local failed_tests
    failed_tests=$(echo "$output" | grep -E "^test .+ \.\.\. FAILED$" | sed 's/^test //' | sed 's/ \.\.\. FAILED$//')

    if [ -z "$failed_tests" ]; then
        # No parseable failures, return original failure
        return "$exit_code"
    fi

    echo ""
    echo "==> Retrying $(echo "$failed_tests" | wc -l) failed test(s) (up to $MAX_RETRIES attempts each)"

    local persistent_failures=()

    while IFS= read -r test_name; do
        [ -z "$test_name" ] && continue
        local passed=false
        for attempt in $(seq 1 "$MAX_RETRIES"); do
            echo "  --> Retry $attempt/$MAX_RETRIES: $test_name"
            local retry_output
            local retry_exit
            retry_output=$(eval "$base_cmd -- --exact \"$test_name\"" 2>&1)
            retry_exit=$?
            if [ "$retry_exit" -eq 0 ]; then
                echo "      PASSED on attempt $attempt"
                passed=true
                break
            fi
        done
        if [ "$passed" = false ]; then
            persistent_failures+=("$test_name")
        fi
    done <<< "$failed_tests"

    if [ "${#persistent_failures[@]}" -eq 0 ]; then
        echo ""
        echo "==> All failures resolved after retries"
        return 0
    fi

    echo ""
    echo "==> Persistent failures after $MAX_RETRIES retries:"
    for f in "${persistent_failures[@]}"; do
        echo "    FAILED: $f"
    done
    return 1
}
