// For format details, see https://aka.ms/devcontainer.json.
{
  "name": "libxmtp (Nix)",
  "build": {
    "context": "..",
    "dockerfile": "../Dockerfile"
  },
  "forwardPorts": [],
  "customizations": {
    "vscode": {
      "extensions": [
        "tamasfe.even-better-toml",
        "rust-lang.rust-analyzer",
        "jnoortheen.nix-ide",
        "mkhl.direnv"
      ]
    }
  },
  "runArgs": ["--network=host"],
  "mounts": [
    // Mount Docker socket so the container can use the Docker CLI
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "postStartCommand": "if ! pgrep -x nix-daemon > /dev/null; then nix-daemon & disown; fi",
  "postCreateCommand": "direnv allow /workspaces/libxmtp"
}
